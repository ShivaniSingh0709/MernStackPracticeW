<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Chat</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <h1>View Chat</h1>
    <div class="chat-details">
        <p class="sender-show"><strong>Sender:</strong> <%= chat.from %></p>
        <p class="receiver-show"><strong>Receiver:</strong> <%= chat.to %></p>
        <p class="message-show"><strong>Message:</strong> <%= chat.msg %></p>
    </div>
    <a href="/chats/<%= chat._id %>/edit" class="btn btn-primary"><i class="fas fa-edit"></i> Edit Chat</a>
    <form action="/chats/<%= chat._id %>?_method=DELETE" method="POST" style="display:inline;">
        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this chat?');">
            <i class="fas fa-trash"></i> Delete Chat
        </button>
    </form>
</html>